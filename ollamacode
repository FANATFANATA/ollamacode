#!/bin/bash
# Launcher script for OllamaCode - can be run from anywhere

# Get the actual directory where the script is located (handles symlinks)
if [ -L "$0" ]; then
    # If called via symlink, resolve it
    SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
else
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
fi

VENV_PYTHON="$SCRIPT_DIR/venv/bin/python"

# Check if virtual environment exists
if [ ! -f "$VENV_PYTHON" ]; then
    echo "❌ Virtual environment not found. Running setup..."
    cd "$SCRIPT_DIR"
    python3 -m venv venv
    source venv/bin/activate
    pip install --upgrade pip
    pip install -r requirements.txt
    deactivate
fi

# Run the main script with the virtual environment's Python
exec "$VENV_PYTHON" "$SCRIPT_DIR/main.py" "$@"

